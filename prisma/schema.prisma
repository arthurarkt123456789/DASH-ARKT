generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model LedgerEntryLine {
  id            BigInt   @id
  label         String   @default("")
  entryLabel    String   @default("")
  debit         Float
  credit        Float
  date          DateTime @db.Date
  accountNumber String
  createdAt     DateTime
  updatedAt     DateTime
  syncedAt      DateTime @default(now())

  @@index([date])
  @@index([accountNumber])
}

model SyncLog {
  id            Int       @id @default(autoincrement())
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  linesUpserted Int       @default(0)
  error         String?
}
